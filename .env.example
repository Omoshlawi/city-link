# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/city-link"

# ── App ───────────────────────────────────────────────────────────────────────
# Port the NestJS server listens on
PORT=2000

# ── Better Auth ───────────────────────────────────────────────────────────────
# Base URL of this API (used for OAuth callbacks and email links)
BETTER_AUTH_URL=http://localhost:2000
# Random secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Domain used for temporary emails created during phone-number sign-up
TEMP_EMAIL_DOMAIN=citylink.app
# URL of the frontend app (used to build verification / reset links in emails)
FRONTEND_URL=http://localhost:5173

# ── Admin seed ────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@citylink.app
# Set to true to skip seeding if the admin user already exists
ADMIN_SKIP_SEED_IF_EXISTS=true

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by BullMQ for job queues
REDIS_DB_URL=redis://user:password@localhost:6379

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Local dev: run Mailpit (https://mailpit.axllent.org) — web UI at http://localhost:8025
# Production: set to your SMTP provider (SendGrid, SES, etc.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@citylink.app

# ── Expo Push (optional) ──────────────────────────────────────────────────────
# Expo push access token — only needed for higher push notification rate limits
# EXPO_ACCESS_TOKEN=
